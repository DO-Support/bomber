# Copy to .env for LOCAL dev only. In Docker, use compose secrets (see README).
# Never commit .env or the secrets/ files.

# --- Azure SQL (encrypt on, validated cert) ---
MSSQL_SERVER=your-server.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=YourDatabase
MSSQL_USERNAME=readonly_user
MSSQL_PASSWORD=
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_ENCRYPT=yes
MSSQL_TRUST_SERVER_CERTIFICATE=no

# --- Session / auth ---
# Long random string: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=
SESSION_MAX_AGE=43200
# false for local http dev; true in prod (behind nginx TLS)
SESSION_HTTPS_ONLY=false
# JSON {username: bcrypt_hash} — generate with scripts/gen_password_hash.py
APP_USERS={"alice":"$2b$12$replace_with_a_real_hash"}

# --- Query cache ---
CACHE_TTL=300
CACHE_MAXSIZE=64
