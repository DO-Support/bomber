# Copy to .env and fill in. Never commit .env.
MSSQL_SERVER=your-sql-server.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=YourDatabase
MSSQL_USERNAME=
MSSQL_PASSWORD=
# Driver as installed on the client machine.
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# Azure SQL requires encryption with a valid certificate.
MSSQL_ENCRYPT=yes
MSSQL_TRUST_SERVER_CERTIFICATE=no
